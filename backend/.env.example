# OAuth Credentials
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# JWT
JWT_SECRET_KEY=change-this-to-a-random-secret-string

# Proxy
PROXY_DOMAIN=gw.ipmobi.net
TRIAL_DURATION_MINUTES=15
TRIAL_MAX_BYTES=104857600

# URLs
BACKEND_URL=http://localhost:8090
FRONTEND_URL=http://localhost:3000

# SSH (optional, for 3proxy provisioning)
SSH_HOST=
SSH_USER=
SSH_KEY_PATH=

# DB
DATABASE_URL=sqlite+aiosqlite:///./trial.db
